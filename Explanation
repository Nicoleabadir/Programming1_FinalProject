    this.storyMode = storyMode;
}

METHODS
--------------------------------------------------------------------------------
startSolo()
toString()

================================================================================
ONLINEGAME CLASS (extends Game)
================================================================================

FIELDS
--------------------------------------------------------------------------------
requiresInternet : boolean (always true)

CONSTRUCTOR
--------------------------------------------------------------------------------
public OnlineGame(int id, String title, Genre genre, PlatForm platform,
                  AgeRating ageRating) {
