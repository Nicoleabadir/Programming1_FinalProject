}

METHODS
--------------------------------------------------------------------------------
startOnline()
toString()

================================================================================
MULTIPLAYERGAME CLASS (extends Game)
================================================================================

FIELDS
--------------------------------------------------------------------------------
maxPlayers : int
players    : ArrayList<String>

CONSTRUCTOR
--------------------------------------------------------------------------------
public MultiplayerGame(int id, String title, Genre genre, PlatForm platform,
                       AgeRating ageRating, int maxPlayers) {
    super(id, title, genre, ageRating, platform);
    this.maxPlayers = maxPlayers;
    this.players = new ArrayList<>();
}

METHODS
--------------------------------------------------------------------------------
addPlayer(name)
